SECRET_KEY=change-me
FLASK_DEBUG=False

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_SENDER_EMAIL=noreply@digikul.in

SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
SOCKETIO_ASYNC_MODE=eventlet

UPLOAD_FOLDER=/app/uploads
COMPRESSED_FOLDER=/app/compressed
RECORDING_DIRECTORY=/app/recordings

ENABLE_RECORDING=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_QUIZ_ANALYTICS=True
ENABLE_COHORT_SCOPING=True

